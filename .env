# YonCockpit 智能驾驶舱配置

# 适配器类型: mock | http | yonclaw
# mock    - 使用本地静态数据（默认，无需外部依赖）
# http    - 通过 HTTP REST API 对接任意智能体平台
# yonclaw - 对接 YonClaw / OpenClaw 内核
ADAPTER_TYPE=mock

# HTTP / YonClaw 适配器配置（当 ADAPTER_TYPE 非 mock 时必填）
# AGENT_PLATFORM_URL=http://localhost:8080
# AGENT_PLATFORM_API_KEY=your-api-key

# 服务端口号
PORT=3001
